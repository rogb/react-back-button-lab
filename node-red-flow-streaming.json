    {
        "id": "memory_stream_function",
        "type": "function",
        "z": "stream_upload_flow",
        "name": "Stream body to memory",
        "func": "const rawName =\n    msg.req.params.filename ||\n    msg.req.headers['x-filename'] ||\n    `upload-${Date.now()}.bin`;\n\nconst fileName = decodeURIComponent(rawName)\n    .split(/[\\\\/]/)\n    .pop()\n    .replace(/[^a-zA-Z0-9._-]/g, '_');\n    \nlet fileSize = 0;\nconst chunks = [];\n\nmsg.req.on('data', chunk => {\n    fileSize += chunk.length;\n    chunks.push(chunk);\n});\n\nmsg.req.on('end', () => {\n    const buffer = Buffer.concat(chunks);\n\n    // Store in Node-RED memory context\n    flow.set(`uploadedFile:${fileName}`, {\n        fileName,\n        fileSize,\n        content: buffer,\n        uploadedAt: new Date().toISOString()\n    });\n\n    msg.statusCode = 200;\n    msg.payload = {\n        fileName,\n        fileSize,\n        storedInMemoryKey: `uploadedFile:${fileName}`\n    };\n\n    node.send(msg);\n    node.done();\n});\n\nmsg.req.on('error', err => {\n    node.error(err, msg);\n\n    msg.statusCode = 500;\n    msg.payload = {\n        error: 'Upload failed',\n        details: err.message\n    };\n\n    node.send(msg);\n    node.done();\n});\n\nreturn;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [
