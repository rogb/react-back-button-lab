    {
        "id": "cb514b1878499c39",
        "type": "function",
        "z": "stream_upload_flow",
        "name": "Save buffered body to disk",
        "func": "const uploadDir = \"C:\\\\junk\";\nfs.mkdirSync(uploadDir, { recursive: true });\n\nconst rawName = msg.req.params.filename || msg.req.headers[\"x-filename\"] || `upload-${Date.now()}.bin`;\n\nconst fileName = path.basename(decodeURIComponent(rawName)).replace(/[^a-zA-Z0-9._ -]/g, \"_\");\nconst filePath = path.join(uploadDir, fileName);\n\nconst body = msg.req.body;\n\nif (!Buffer.isBuffer(body)) {\n    msg.statusCode = 400;\n    msg.payload = {\n        error: \"Expected binary buffer in msg.req.body\",\n        bodyType: typeof body\n    };\n    return msg;\n}\n\nfs.writeFileSync(filePath, body);\n\nmsg.statusCode = 200;\nmsg.payload = {\n    fileName,\n    fileSize: body.length,\n    savedTo: filePath\n};\n\nnode.status({ fill: \"green\", shape: \"dot\", text: `${body.length} bytes saved` });\n\ndelete msg.req.body;\n\nreturn msg;",
