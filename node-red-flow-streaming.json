    {
        "id": "stream_upload_function",
        "type": "function",
        "z": "stream_upload_flow",
        "name": "Stream body to disk",
        "func": "const uploadDir = \"C:\\\\junk\";\nfs.mkdirSync(uploadDir, { recursive: true });\n\nconst rawName =\n    msg.req.params.filename ||\n    msg.req.headers[\"x-filename\"] ||\n    `upload-${Date.now()}.bin`;\n\nconst fileName = path.basename(decodeURIComponent(rawName))\n    .replace(/[^a-zA-Z0-9._ -]/g, \"_\");\n\nconst filePath = path.join(uploadDir, fileName);\n\nconst body = msg.req.body;\n\nif (!body) {\n    msg.statusCode = 400;\n    msg.payload = {\n        error: \"No request body found\"\n    };\n    return msg;\n}\n\nconst buffer = Buffer.isBuffer(body)\n    ? body\n    : Buffer.from(body);\n\nfs.writeFileSync(filePath, buffer);\n\nmsg.statusCode = 200;\nmsg.payload = {\n    fileName,\n    fileSize: buffer.length,\n    savedTo: filePath\n};\n\nreturn msg;",
